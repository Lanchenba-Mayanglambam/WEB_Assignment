<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Habibi Restaurant — Menu</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,500&family=Jost:wght@300;500&display=swap');
:root{--ink:#1a120b;--terra:#c2592f;--gold:#cc9a4a;--gold2:#e0c388;--cream:#f3e9d6;--cream2:#cdbfa5}
*{margin:0;padding:0;box-sizing:border-box}
body{min-height:100vh;background:var(--ink) radial-gradient(60% 50% at 50% 0%,rgba(194,89,47,.16),transparent 70%);
font-family:'Jost',sans-serif;color:var(--cream);padding:48px 24px;text-align:center}
h1{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(34px,6vw,52px);margin-bottom:8px;animation:fadeUp .6s ease both}
.eyebrow{font-size:12px;letter-spacing:6px;text-transform:uppercase;color:var(--gold2);display:block;margin-bottom:14px;animation:fadeUp .6s ease both}
.back{display:inline-block;margin-top:30px;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:18px;
color:var(--terra);text-decoration:none;border-bottom:1px solid #8f3f22;transition:.25s}
.back:hover{color:var(--gold);border-color:var(--gold);transform:translateX(-4px);display:inline-block}
form{display:inline-flex;gap:10px;margin-top:20px;animation:fadeUp .6s ease .1s both}
select{background:rgba(243,233,214,.05);border:1px solid rgba(204,154,74,.35);border-radius:3px;
color:var(--cream);font-family:'Jost',sans-serif;font-size:14px;padding:10px 14px;outline:none;cursor:pointer;transition:border-color .25s}
select:focus{border-color:var(--gold)}
form button{font-size:13px;letter-spacing:2px;text-transform:uppercase;color:var(--ink);
background:linear-gradient(180deg,var(--gold2),var(--gold));border:none;border-radius:3px;padding:0 22px;cursor:pointer;
transition:filter .2s,transform .2s}
form button:hover{filter:brightness(1.1);transform:translateY(-1px)}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;max-width:1240px;margin:30px auto 0;text-align:left}
.card{background:linear-gradient(180deg,#2c1d12,#20140d);border:1px solid rgba(204,154,74,.3);border-radius:6px;
overflow:hidden;box-shadow:0 20px 40px -25px rgba(0,0,0,.7);animation:fadeUp .5s ease both;
transition:transform .3s,box-shadow .3s,border-color .3s}
.card:hover{transform:translateY(-6px);box-shadow:0 30px 50px -20px rgba(0,0,0,.8);border-color:rgba(204,154,74,.6)}
.thumb{height:170px;background:#000;overflow:hidden}
.thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s ease,filter .4s ease}
.card:hover .thumb img{transform:scale(1.08);filter:brightness(1.05)}
.body{padding:20px 24px 24px}
.cat{font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--gold2)}
.name{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:26px;margin:8px 0 12px}
.row{display:flex;justify-content:space-between;align-items:center;font-size:15px;color:var(--cream2)}
.price{font-family:'Cormorant Garamond',serif;font-style:italic;color:var(--terra);font-size:22px}
.stars{color:var(--gold)}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
</style>
</head>
<body>
<%
const pool=['1565299624946-b28f40a0ae38','1568901346375-23c9450c58cd','1604382354936-07c5d9983bd3',
'1565958011703-44f9829ba187','1606756790138-261d2b21cd75','1603133872878-684f208fb84b',
'1512621776951-a57141f2eefd','1576107232684-1279f390859f','1551183053-bf91a1d81141',
'1455619452474-d2be8b1e70cd','1565555326816-e6b00bdd4c0f','1547592166-23ac45744acd',
'1546069901-ba9599a7e63c','1559847844-5315695dadae','1581873372796-635b67ca2008',
'1626700051175-6818013e1d4f','1473093295043-cdd812d0e601','1631452180519-c014fe946bc7'];
const img=n=>{let h=0;for(const c of n)h=(h*31+c.charCodeAt(0))>>>0;
return `https://images.unsplash.com/photo-${pool[h%pool.length]}?w=300&h=200&fit=crop&q=60`};
%>
<span class="eyebrow">LB Kitchen &amp; Grill</span>
<h1>All Items</h1>

<form action="/sort/price" method="GET">
    <select name="order">
        <option value="asc">Low to High</option>
        <option value="desc">High to Low</option>
    </select>

    <button type="submit">Filter</button>
</form>

<div class="grid">
<% allMenu.forEach((element) => { %>
  <div class="card">
    <div class="thumb"><img src="<%= img(element.FoodName) %>" alt="<%= element.FoodName %>" loading="lazy"></div>
    <div class="body">
      <span class="cat"><%= element.Category %></span>
      <div class="name"><%= element.FoodName %></div>
      <div class="row"><span class="price">$<%= element.Price %></span><span><%= element.Quantity %> left</span></div>
      <div class="row"><span class="stars">★ <%= element.Rating %></span></div>
    </div>
  </div>
<% }); %>
</div>

<a class="back" href="/">← Back Home</a>
</body>
</html>